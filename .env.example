# ============================================================================
# Casper Agent Rail — environment template
# Copy to `.env` and fill in the SECRETS. Testnet defaults are pre-filled.
# ============================================================================

# ---- Shared ----------------------------------------------------------------
CAIP2_CHAIN_ID=casper:casper-test

# ---- Facilitator (settles CEP-18 payments on-chain; pays gas) --------------
# The facilitator account needs testnet CSPR for gas.
PORT=4022
CASPER_NETWORKS=casper:casper-test
RPCURL_CASPER_CASPER_TEST=https://node.testnet.casper.network/rpc
SECRET_KEY_ALGO_CASPER_CASPER_TEST=ed25519
# SECRET: PEM of the facilitator key (escaped \n or literal newlines).
SECRET_KEY_PEM_CASPER_CASPER_TEST="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ---- Proxy / resource server (the rail) ------------------------------------
PROXY_PORT=4021
FACILITATOR_URL=http://localhost:4022
FACILITATOR_API_KEY=
# SECRET: Casper account hash that receives payments (00<64 hex>). The operator.
PAYEE_ADDRESS=00...
# WCSPR token on Casper testnet — already deployed, no action needed.
ASSET_NAME=Wrapped CSPR
ASSET_PACKAGE=3d80df21ba4ee4d66a2a1f60c32570dd5685e4b279f6538162a5fd1314847c1e
# Price charged per /v1/speak call, in WCSPR motes (9 decimals). 100000000 = 0.1 WCSPR.
PRICE_MOTES=100000000
# SECRET: your Deepgram API key (free credits). The operator float.
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# ---- Agent (client that pays per call) -------------------------------------
SERVER_URL=http://localhost:4021
# SECRET: PEM key for the agent. This account holds the WCSPR budget.
CLIENT_PRIVATE_KEY_PATH=./agent.pem
CLIENT_KEY_ALGO=ed25519
# Text the demo agent will turn into speech.
TEXT=Hello. I am an autonomous agent, and I just paid for this sentence on Casper.
