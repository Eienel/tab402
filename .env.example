# ============================================================================
# Casper Agent Rail — environment template. Copy to `.env` and fill SECRETS.
# Self-contained: one funded account runs facilitator + deploys token + treasury.
# ============================================================================

CAIP2_CHAIN_ID=casper:casper-test

# ---- Self-hosted facilitator (settles CEP-18 on-chain; pays gas) -----------
PORT=4022
CASPER_NETWORKS=casper:casper-test
RPCURL_CASPER_CASPER_TEST=https://node.testnet.casper.network/rpc
SECRET_KEY_ALGO_CASPER_CASPER_TEST=ed25519
# SECRET: facilitator/treasury PEM, one line with \n. Fund this acct with CSPR.
SECRET_KEY_PEM_CASPER_CASPER_TEST="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ---- Proxy / rail ----------------------------------------------------------
PROXY_PORT=4021
FACILITATOR_URL=http://localhost:4022
FACILITATOR_API_KEY=
# SECRET: account hash (00<64hex>) that receives payments (the treasury).
PAYEE_ADDRESS=00...
# Our own CEP-18 x402 token. ASSET_PACKAGE is filled by `npm run deploy-token`.
ASSET_NAME=Casper X402 Token
ASSET_SYMBOL=X402
ASSET_PACKAGE=b74d49efc3ca7ce82225213e0e77eba641ea39e3417dbdcf72790fdd626be2d0
PRICE_MOTES=100000000
# SECRET: your Deepgram API key (free credits).
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# ---- Agent (holds X402 tokens; balance = hard cap). Needs NO CSPR. ---------
SERVER_URL=http://localhost:4021
CLIENT_PRIVATE_KEY_PATH=./agent.pem
CLIENT_KEY_ALGO=ed25519
TEXT=Hello. I am an autonomous agent, and I just paid for this sentence on Casper.

# ---- Token deploy / treasury -----------------------------------------------
# Local dev: point at a PEM file. Deploy (Fly/Railway): set DEPLOYER_PRIVATE_KEY_PEM
# as a platform secret instead (one line, \n-escaped) so no key file ships.
DEPLOYER_PRIVATE_KEY_PATH=./facilitator.pem
# DEPLOYER_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
DEPLOYER_KEY_ALGO=ed25519
# account-hash-... of the agent (receives the starting token balance).
AGENT_ACCOUNT_HASH=account-hash-...
TOKEN_INITIAL_SUPPLY=1000000000000000
AGENT_FUND_AMOUNT=50000000000
